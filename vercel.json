{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "startServer.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/startServer.cjs" },
    { "src": "/health",   "dest": "/startServer.cjs" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}