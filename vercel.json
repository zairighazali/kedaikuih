{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "startServer.cjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/startServer.cjs" },
    { "src": "/health", "dest": "/startServer.cjs" },
    { "src": "/(.*)", "dest": "/startServer.cjs" }
  ]
}