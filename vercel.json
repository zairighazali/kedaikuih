{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "startServer.cjs",
      "use": "@vercel/node@4.0.0"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/startServer.cjs" },
    { "src": "/health",   "dest": "/startServer.cjs" },
    { "handle": "filesystem" },
    { "src": "/(.*)",     "dest": "/index.html" }
  ]
}