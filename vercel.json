{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "startServer.cjs",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/startServer.cjs" },
    { "source": "/health",   "destination": "/startServer.cjs" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}