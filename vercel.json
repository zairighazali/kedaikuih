{
  "version": 2,
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "startServer.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/startServer.cjs"
    },
    {
      "src": "/health",
      "dest": "/startServer.cjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}